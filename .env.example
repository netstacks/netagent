# Database
POSTGRES_PASSWORD=your_secure_password

# =============================================================================
# LLM Providers
# =============================================================================

# Gemini via Apigee (default provider)
APIGEE_CLIENT_ID=your_client_id
APIGEE_CLIENT_SECRET=your_client_secret
APIGEE_TOKEN_URL=https://apigee.company.com/oauth/token
GEMINI_API_URL=https://apigee.company.com/gemini/v1
# GEMINI_EMBEDDING_API_URL=https://apigee.company.com/gemini/v1/embedding
# GEMINI_USER_EMAIL=your_email@company.com

# Anthropic Claude via AWS Bedrock (optional - only needed if using Bedrock models)
# Models: anthropic.claude-sonnet-4-20250514-v1:0, anthropic.claude-haiku-4-20250414-v1:0
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_BEDROCK_REGION=us-west-1

# =============================================================================
# Security
# =============================================================================

# Encryption key for credentials storage
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key

# =============================================================================
# Integrations
# =============================================================================

# Email (SMTP)
SMTP_SERVER=smtp.company.com
SMTP_PORT=587
SMTP_FROM=netagent@company.com

# Slack Bot
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Confluence (for RAG knowledge bases)
CONFLUENCE_BASE_URL=https://company.atlassian.net/wiki
CONFLUENCE_USERNAME=your_email@company.com
CONFLUENCE_API_TOKEN=your_confluence_api_token

# =============================================================================
# Development
# =============================================================================

# Development mode (bypasses ALB auth, uses mock user)
DEV_MODE=false
